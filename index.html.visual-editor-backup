    const typeLabels = { new: "신규", improve: "개선", fix: "수정", info: "안내" };
    const versionSelect = document.getElementById("versionSelect");
    const hero = document.getElementById("releaseHero");
    const content = document.getElementById("releaseContent");
    const sideNav = document.getElementById("sideNav");
    const mobileNav = document.getElementById("mobileNav");
    const modal = document.getElementById("imageModal");
    const modalImage = document.getElementById("modalImage");
    let observer;

    function itemCount(release) {
      return release.sections.reduce((total, section) => total + section.items.length, 0);
    }

    function renderRelease(version) {
      const release = releases.find(item => item.version === version);
      if (!release) {
        content.innerHTML = '<p class="empty-state">선택한 릴리스를 찾을 수 없습니다.</p>';
        return;
      }

      hero.innerHTML = `
        <span class="eyebrow">Product update</span>
        <h1>XneoPicasso ${release.version}</h1>
        <p class="hero-copy">${release.summary}</p>
        <div class="release-facts">
          <span class="fact">Previous <strong>${release.previousVersion}</strong></span>
          <span class="fact">Changes <strong>${itemCount(release)}</strong></span>
          ${release.scopes.map(scope => `<span class="fact">${scope}</span>`).join("")}
        </div>
      `;

      const navMarkup = release.sections.map(section => `<a href="#${section.id}">${section.title}</a>`).join("");
      sideNav.innerHTML = navMarkup;
      mobileNav.innerHTML = navMarkup;

      content.innerHTML = release.sections.map((section, sectionIndex) => `
        <section class="release-section" id="${section.id}">
          <header class="section-head">
            <span class="section-number">${String(sectionIndex + 1).padStart(2, "0")}</span>
            <div>
              <h2>${section.title}</h2>
              <p>${section.description}</p>
            </div>
          </header>
          <div class="change-list">
            ${section.items.map(item => `
              <section class="change">
                <span class="change-index">${String(item.number).padStart(2, "0")}</span>
                <div>
                  <div class="change-title-row">
                    <h3>${item.title}</h3>
                    <span class="tag tag-${item.type}">${typeLabels[item.type]}</span>
                  </div>
                  ${item.body ? `<p>${item.body}</p>` : ""}
                  ${item.note ? `<aside class="note">${item.note}</aside>` : ""}
                  ${item.warning ? `<aside class="warning-note">${item.warning}</aside>` : ""}
                  ${item.image ? `
                    <button class="change-image" type="button" data-image="${item.image.src}" data-alt="${item.image.alt}">
                      <img src="${item.image.src}" alt="${item.image.alt}">
                      <span class="image-caption">${item.image.caption} · 클릭하여 확대</span>
                    </button>` : ""}
                  ${item.images ? `
                    <div class="image-gallery${item.imageLayout === "compact" ? " image-gallery-compact" : ""}">
                      ${item.images.map(image => `
                        <button class="change-image" type="button" data-image="${image.src}" data-alt="${image.alt}">
                          <img src="${image.src}" alt="${image.alt}">
                          <span class="image-caption">${image.caption} · 클릭하여 확대</span>
                        </button>
                      `).join("")}
                    </div>` : ""}
                </div>
              </section>
            `).join("")}
          </div>
        </section>
      `).join("");

      bindImageButtons();
      observeSections();
      window.scrollTo({ top: 0, behavior: "instant" });
    }

    function bindImageButtons() {
      document.querySelectorAll(".change-image").forEach(button => {
        button.addEventListener("click", () => {
          modalImage.src = button.dataset.image;
          modalImage.alt = button.dataset.alt;
          modal.classList.add("open");
          document.body.style.overflow = "hidden";
          modal.querySelector(".modal-close").focus();
        });
      });
    }

    function closeModal() {
      modal.classList.remove("open");
      modalImage.src = "";
      document.body.style.overflow = "";
    }

    function observeSections() {
      if (observer) observer.disconnect();
      const navLinks = [...sideNav.querySelectorAll("a")];
      observer = new IntersectionObserver(entries => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          navLinks.forEach(link => link.classList.toggle("active", link.hash === `#${entry.target.id}`));
        });
      }, { rootMargin: "-25% 0px -65% 0px" });
      document.querySelectorAll(".release-section").forEach(section => observer.observe(section));
    }

    releases.forEach(release => {
      const option = document.createElement("option");
      option.value = release.version;
      option.textContent = `v${release.version}`;
      versionSelect.appendChild(option);
    });
    versionSelect.addEventListener("change", event => renderRelease(event.target.value));
    modal.querySelector(".modal-close").addEventListener("click", closeModal);
    modal.addEventListener("click", event => { if (event.target === modal) closeModal(); });
    document.addEventListener("keydown", event => { if (event.key === "Escape" && modal.classList.contains("open")) closeModal(); });
    renderRelease(releases[0].version);
  </script>


